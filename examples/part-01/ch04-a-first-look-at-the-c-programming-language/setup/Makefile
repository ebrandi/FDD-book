# Makefile for hello.c
#
# Companion for Chapter 4's "Using Makefiles" section.
#
# IMPORTANT: each command line below a rule must begin with a TAB
# character, not spaces. If you see "Invalid line type" from make,
# your editor has turned a tab into spaces. Check with `cat -A`.

hello: hello.c
	cc -o hello hello.c

clean:
	rm -f hello
