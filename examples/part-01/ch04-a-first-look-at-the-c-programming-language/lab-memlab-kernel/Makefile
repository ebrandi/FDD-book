# Makefile for the memlab kernel module (Chapter 4 Mini-Lab 3).
#
# The chapter shows a long manual compile + link command for
# teaching. In practice, the FreeBSD kernel-module build
# infrastructure handles all of that for you, so a three-line
# Makefile is all you need.

KMOD=	memlab
SRCS=	memlab.c

.include <bsd.kmod.mk>
